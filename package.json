{
  "name": "arcbridge",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/",
    "typecheck": "tsc --noEmit -p packages/core/tsconfig.json && tsc --noEmit -p packages/adapters/tsconfig.json && tsc --noEmit -p packages/mcp-server/tsconfig.json && tsc --noEmit -p packages/cli/tsconfig.json",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "clean": "pnpm -r clean",
    "bump": "node scripts/bump-version.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "flatted": ">=3.4.2",
      "hono": ">=4.12.7"
    }
  },
  "engines": {
    "node": ">=22.5.0",
    "pnpm": ">=9.0.0"
  }
}
