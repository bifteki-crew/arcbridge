{
  "name": "@arcbridge/mcp-server",
  "version": "0.3.3",
  "description": "MCP server for ArcBridge — exposes architecture tools to AI coding agents",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bifteki-crew/arcbridge.git",
    "directory": "packages/mcp-server"
  },
  "keywords": [
    "arcbridge",
    "mcp",
    "model-context-protocol",
    "ai-agents"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "arcbridge-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@arcbridge/adapters": "workspace:*",
    "@arcbridge/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
