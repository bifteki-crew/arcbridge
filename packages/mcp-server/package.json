{
  "name": "@archlens/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for ArchLens — exposes architecture tools to AI coding agents",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bifteki-crew/project-archlens.git",
    "directory": "packages/mcp-server"
  },
  "keywords": ["archlens", "mcp", "model-context-protocol", "ai-agents"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "archlens-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@archlens/core": "workspace:*",
    "@archlens/adapters": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  }
}
