{
  "name": "arcbridge",
  "version": "0.1.5",
  "description": "CLI for ArcBridge — architectural awareness for AI coding agents",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bifteki-crew/arcbridge.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "arcbridge",
    "architecture",
    "arc42",
    "cli",
    "ai-agents"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "arcbridge": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@arcbridge/core": "workspace:*",
    "@arcbridge/adapters": "workspace:*"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
