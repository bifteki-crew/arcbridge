{
  "name": "@arcbridge/adapters",
  "version": "0.4.0",
  "description": "Platform adapters for ArcBridge — Claude Code and GitHub Copilot config generators",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bifteki-crew/arcbridge.git",
    "directory": "packages/adapters"
  },
  "keywords": [
    "arcbridge",
    "claude",
    "copilot",
    "ai-agents"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@arcbridge/core": "workspace:*"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
